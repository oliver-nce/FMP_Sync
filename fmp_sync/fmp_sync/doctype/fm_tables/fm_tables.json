  "fields": [
    {
      "fieldname": "table_info_section",
      "fieldtype": "Section Break",
      "label": "Table Information"
    },
    {
      "fieldname": "doctype_source",
      "fieldtype": "Select",
      "label": "DocType Source",
      "options": "Mirror\nNative",
      "default": "Mirror",
      "in_list_view": 1,
      "reqd": 1,
      "description": "Mirror: FMP Sync creates and owns the Frappe DocType from an FM table. Native: link to a DocType already created by another app (no FM table needed)."
    },
    {
      "fieldname": "table_name",
      "fieldtype": "Data",
      "in_list_view": 1,
      "label": "Table Name",
      "unique": 1,
      "read_only": 1,
      "mandatory_depends_on": "eval:doc.doctype_source !== 'Native'",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "table_type",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Table Type",
      "options": "Table\nView",
      "mandatory_depends_on": "eval:doc.doctype_source !== 'Native'",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "fmp_name",
      "fieldtype": "Data",
      "label": "FM Name",
      "description": "Optional custom name for the generated Frappe DocType. If blank, uses table_name.",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "frappe_doctype",
      "fieldtype": "Link",
      "label": "Frappe DocType",
      "options": "DocType",
      "read_only_depends_on": "eval:doc.doctype_source !== 'Native'",
      "mandatory_depends_on": "eval:doc.doctype_source === 'Native'",
      "description": "Mirror mode: auto-filled when schema is mirrored. Native mode: select the existing DocType to sync into."
    },
    {
      "fieldname": "modified_timestamp_field",
      "fieldtype": "Data",
      "label": "Modified Timestamp Field",
      "description": "Auto-detected or manually entered",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "created_timestamp_field",
      "fieldtype": "Data",
      "label": "Created Timestamp Field",
      "description": "Auto-detected or manually entered",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "matching_fields",
      "fieldtype": "Small Text",
      "label": "Matching Fields",
      "description": "Comma-separated list of up to 3 fields to use for matching records during sync (selected during Mirror Schema)",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "sync_settings_section",
      "fieldtype": "Section Break",
      "label": "Sync Settings",
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "sync_direction",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Sync Direction",
      "options": "FM to Frappe\nFrappe to FM\nBoth",
      "default": "FM to Frappe"
    },
    {
      "fieldname": "sync_method",
      "fieldtype": "Select",
      "label": "Sync Method",
      "options": "TS Compare\nTruncate & Replace",
      "default": "TS Compare",
      "depends_on": "eval:doc.sync_direction=='FM to Frappe'",
      "description": "Metadata only in Phase 1"
    },
    {
      "fieldname": "column_break_sync",
      "fieldtype": "Column Break"
    },
    {
      "default": "0",
      "description": "Enable scheduled automatic sync for this table",
      "fieldname": "auto_sync_active",
      "fieldtype": "Check",
      "in_list_view": 1,
      "label": "Auto Sync"
    },
    {
      "default": "Never",
      "description": "Never: read-only from FM. OData Direct: auto-push changes to FM via OData (future). API Required: local edits allowed, FM push handled externally.",
      "fieldname": "write_back_mode",
      "fieldtype": "Select",
      "label": "Write Back Mode",
      "options": "Never\nOData Direct\nAPI Required"
    },
    {
      "default": "0",
      "description": "Automatically push Frappe record changes (creates/updates) back to the FileMaker table via OData (future)",
      "fieldname": "listen_for_changes",
      "fieldtype": "Check",
      "label": "Listen For Changes"
    },
    {
      "fieldname": "sync_status_section",
      "fieldtype": "Section Break",
      "label": "Sync Status",
      "collapsible": 1,
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "last_synced",
      "fieldtype": "Datetime",
      "label": "Last Synced",
      "read_only": 1,
      "description": "Last successful sync timestamp (in Frappe server timezone)"
    },
    {
      "fieldname": "last_sync_status",
      "fieldtype": "Select",
      "label": "Last Sync Status",
      "options": "\nSuccess\nError\nRunning",
      "read_only": 1
    },
    {
      "fieldname": "last_sync_log",
      "fieldtype": "Small Text",
      "label": "Last Sync Log",
      "read_only": 1,
      "description": "Summary or error message from last sync"
    },
    {
      "fieldname": "generated_doctype_section",
      "fieldtype": "Section Break",
      "label": "Generated DocType",
      "collapsible": 1,
      "depends_on": "eval:doc.doctype_source !== 'Native'"
    },
    {
      "fieldname": "column_mapping",
      "fieldtype": "JSON",
      "label": "Column Mapping",
      "read_only": 1,
      "hidden": 1,
      "description": "JSON mapping of FM field names to Frappe fieldnames"
    },
    {
      "fieldname": "name_field_column",
      "fieldtype": "Data",
      "label": "Name Field Column",
      "read_only": 1,
      "hidden": 1,
      "description": "FM field that maps directly to Frappe name (e.g. id)"
    },
    {
      "fieldname": "auto_generated_columns",
      "fieldtype": "Small Text",
      "label": "Auto Generated Columns",
      "read_only": 1,
      "hidden": 1,
      "description": "Comma-separated FM fields that are auto-generated (e.g. auto_increment) - skipped when writing records back to source"
    },
    {
      "fieldname": "skipped_fields",
      "fieldtype": "JSON",
      "label": "Skipped Fields",
      "read_only": 1,
      "hidden": 1,
      "description": "JSON list of FM fields skipped during mirroring (unstored calcs, containers, repeating fields)"
    },
    {
      "fieldname": "stored_calc_fields",
      "fieldtype": "JSON",
      "label": "Stored Calculation Fields",
      "read_only": 1,
      "hidden": 1,
      "description": "JSON list of FM stored calculation fields imported as ordinary fields"
    },
    {
      "fieldname": "mirror_status",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Mirror Status",
      "options": "Pending\nMirrored\nLinked\nError",
      "default": "Pending",
      "read_only": 1
    },
    {
      "fieldname": "external_config_section",
      "fieldtype": "Section Break",
      "label": "Native DocType Configuration",
      "depends_on": "eval:doc.doctype_source=='Native'",
      "collapsible": 0
    },
    {
      "fieldname": "external_config_description",
      "fieldtype": "HTML",
      "label": "Native Config Description",
      "depends_on": "eval:doc.doctype_source=='Native'",
      "options": "<p class='text-muted'>This entry links to an existing Frappe DocType created by another app. No FileMaker table is involved. Select the target DocType above, then use <strong>Link & Configure</strong> in the Actions menu to complete the setup.</p>"
    },
    {
      "fieldname": "error_log",
      "fieldtype": "Small Text",
      "label": "Error Log",
      "read_only": 1
    }
  ],
  "index_web_pages_for_search": 1,
