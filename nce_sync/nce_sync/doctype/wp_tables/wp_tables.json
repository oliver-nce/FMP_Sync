{
  "actions": [],
  "allow_rename": 1,
  "creation": "2026-02-06 00:00:00.000000",
  "doctype": "DocType",
  "engine": "InnoDB",
  "field_order": [
    "table_info_section",
    "doctype_source",
    "table_name",
    "table_type",
    "nce_name",
    "column_break_1",
    "frappe_doctype",
    "modified_timestamp_field",
    "created_timestamp_field",
    "matching_fields",
    "sync_settings_section",
    "sync_direction",
    "sync_method",
    "column_break_sync",
    "auto_sync_active",
    "write_back_mode",
    "listen_for_changes",
    "sync_status_section",
    "last_synced",
    "last_sync_status",
    "last_sync_log",
    "generated_doctype_section",
    "mirror_status",
    "column_mapping",
    "name_field_column",
    "auto_generated_columns",
    "external_config_section",
    "external_config_description",
    "error_log"
  ],
  "fields": [
    {
      "fieldname": "table_info_section",
      "fieldtype": "Section Break",
      "label": "Table Information"
    },
    {
      "fieldname": "doctype_source",
      "fieldtype": "Select",
      "label": "DocType Source",
      "options": "Mirror\nExternal",
      "default": "Mirror",
      "in_list_view": 1,
      "reqd": 1,
      "description": "Mirror: NCE Sync creates and owns the Frappe DocType from a WP table. External: link to a DocType already created by another app (no WP table needed)."
    },
    {
      "fieldname": "table_name",
      "fieldtype": "Data",
      "in_list_view": 1,
      "label": "Table Name",
      "unique": 1,
      "read_only": 1,
      "mandatory_depends_on": "eval:doc.doctype_source !== 'External'",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "table_type",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Table Type",
      "options": "Table\nView",
      "mandatory_depends_on": "eval:doc.doctype_source !== 'External'",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "nce_name",
      "fieldtype": "Data",
      "label": "NCE Name",
      "description": "Optional custom name for the generated Frappe DocType. If blank, uses table_name.",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "column_break_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "frappe_doctype",
      "fieldtype": "Link",
      "label": "Frappe DocType",
      "options": "DocType",
      "read_only_depends_on": "eval:doc.doctype_source !== 'External'",
      "mandatory_depends_on": "eval:doc.doctype_source === 'External'",
      "description": "Mirror mode: auto-filled when schema is mirrored. External mode: select the existing DocType to sync into."
    },
    {
      "fieldname": "modified_timestamp_field",
      "fieldtype": "Data",
      "label": "Modified Timestamp Field",
      "description": "Auto-detected or manually entered",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "created_timestamp_field",
      "fieldtype": "Data",
      "label": "Created Timestamp Field",
      "description": "Auto-detected or manually entered",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "matching_fields",
      "fieldtype": "Small Text",
      "label": "Matching Fields",
      "description": "Comma-separated list of up to 3 fields to use for matching records during sync (selected during Mirror Schema)",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "sync_settings_section",
      "fieldtype": "Section Break",
      "label": "Sync Settings",
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "sync_direction",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Sync Direction",
      "options": "WP to Frappe\nFrappe to WP\nBoth",
      "default": "WP to Frappe"
    },
    {
      "fieldname": "sync_method",
      "fieldtype": "Select",
      "label": "Sync Method",
      "options": "TS Compare\nTruncate & Replace",
      "default": "TS Compare",
      "depends_on": "eval:doc.sync_direction=='WP to Frappe'",
      "description": "Metadata only in Phase 1"
    },
    {
      "fieldname": "column_break_sync",
      "fieldtype": "Column Break"
    },
    {
      "default": "0",
      "description": "Enable scheduled automatic sync for this table",
      "fieldname": "auto_sync_active",
      "fieldtype": "Check",
      "in_list_view": 1,
      "label": "Auto Sync"
    },
    {
      "default": "Never",
      "description": "Never: read-only from WP. SQL Direct: auto-push changes to WP via SQL. API Required: local edits allowed, WP push handled externally.",
      "fieldname": "write_back_mode",
      "fieldtype": "Select",
      "label": "Write Back Mode",
      "options": "Never\nSQL Direct\nAPI Required"
    },
    {
      "default": "0",
      "description": "Automatically push Frappe record changes (creates/updates) back to the WordPress table via SQL",
      "fieldname": "listen_for_changes",
      "fieldtype": "Check",
      "label": "Listen For Changes"
    },
    {
      "fieldname": "sync_status_section",
      "fieldtype": "Section Break",
      "label": "Sync Status",
      "collapsible": 1,
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "last_synced",
      "fieldtype": "Datetime",
      "label": "Last Synced",
      "read_only": 1,
      "description": "Last successful sync timestamp (in Frappe server timezone)"
    },
    {
      "fieldname": "last_sync_status",
      "fieldtype": "Select",
      "label": "Last Sync Status",
      "options": "\nSuccess\nError\nRunning",
      "read_only": 1
    },
    {
      "fieldname": "last_sync_log",
      "fieldtype": "Small Text",
      "label": "Last Sync Log",
      "read_only": 1,
      "description": "Summary or error message from last sync"
    },
    {
      "fieldname": "generated_doctype_section",
      "fieldtype": "Section Break",
      "label": "Generated DocType",
      "collapsible": 1,
      "depends_on": "eval:doc.doctype_source !== 'External'"
    },
    {
      "fieldname": "column_mapping",
      "fieldtype": "JSON",
      "label": "Column Mapping",
      "read_only": 1,
      "hidden": 1,
      "description": "JSON mapping of WP column names to Frappe fieldnames"
    },
    {
      "fieldname": "name_field_column",
      "fieldtype": "Data",
      "label": "Name Field Column",
      "read_only": 1,
      "hidden": 1,
      "description": "WP column that maps directly to Frappe name (e.g. id)"
    },
    {
      "fieldname": "auto_generated_columns",
      "fieldtype": "Small Text",
      "label": "Auto Generated Columns",
      "read_only": 1,
      "hidden": 1,
      "description": "Comma-separated WP columns that are auto-generated (e.g. auto_increment) - skipped when writing records back to source"
    },
    {
      "fieldname": "mirror_status",
      "fieldtype": "Select",
      "in_list_view": 1,
      "label": "Mirror Status",
      "options": "Pending\nMirrored\nLinked\nError",
      "default": "Pending",
      "read_only": 1
    },
    {
      "fieldname": "external_config_section",
      "fieldtype": "Section Break",
      "label": "External DocType Configuration",
      "depends_on": "eval:doc.doctype_source=='External'",
      "collapsible": 0
    },
    {
      "fieldname": "external_config_description",
      "fieldtype": "HTML",
      "label": "External Config Description",
      "depends_on": "eval:doc.doctype_source=='External'",
      "options": "<p class='text-muted'>This entry links to an existing Frappe DocType created by another app. No WordPress table is involved. Select the target DocType above, then use <strong>Link & Configure</strong> in the Actions menu to complete the setup.</p>"
    },
    {
      "fieldname": "error_log",
      "fieldtype": "Small Text",
      "label": "Error Log",
      "read_only": 1
    }
  ],
  "index_web_pages_for_search": 1,
  "links": [],
  "modified": "2026-03-12 00:00:00.000000",
  "modified_by": "Administrator",
  "module": "NCE Sync",
  "name": "WP Tables",
  "naming_rule": "By fieldname",
  "owner": "Administrator",
  "permissions": [
    {
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "read": 1,
      "report": 1,
      "role": "System Manager",
      "share": 1,
      "write": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "states": [],
  "track_changes": 1
}
